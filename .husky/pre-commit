#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

echo "🔍 Running ESLint..."
npx eslint src/ --max-warnings 100
lint_result=$?

if [ $lint_result -ne 0 ]; then
  echo "❌ ESLint failed. Please fix the errors above."
  exit 1
fi

echo "✅ ESLint passed (with some warnings - OK for now)!"
echo "✅ All checks passed!"
